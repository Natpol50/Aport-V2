{% extends 'admin/base.html.twig' %}

{% block title %}{{ isNew ? 'Add Project' : 'Edit Project' }} - Admin{% endblock %}

{% block content %}
<div class="admin-content container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold">{{ isNew ? 'Create New Project' : 'Edit Project: ' ~ project.title }}</h1>
        <a href="/admin/projects" class="bg-surface hover:bg-gray-700 px-4 py-2 rounded">Cancel</a>
    </div>

    <form action="{{ isNew ? '/admin/project/create' : '/admin/project/update/' ~ project.id }}" method="POST" class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Left Column: Base Data -->
            <div class="bg-surface p-6 rounded-lg shadow-md space-y-4">
                <h2 class="text-xl font-bold border-b border-gray-700 pb-2 mb-4">Project Details</h2>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Type</label>
                        <div class="flex gap-2">
                            <select name="type" id="type_select" class="flex-grow bg-background border border-gray-600 p-2 rounded" onchange="if(this.value==='other_custom'){document.getElementById('custom_type_container').classList.remove('hidden');}else{document.getElementById('custom_type_container').classList.add('hidden');}">
                                <option value="web" {{ (formData.type|default(project.type|default(''))) == 'web' ? 'selected' : '' }}>Web</option>
                                <option value="mobile" {{ (formData.type|default(project.type|default(''))) == 'mobile' ? 'selected' : '' }}>Mobile</option>
                                <option value="design" {{ (formData.type|default(project.type|default(''))) == 'design' ? 'selected' : '' }}>Design</option>
                                {% if project.type and project.type not in ['web', 'mobile', 'design'] %}
                                    <option value="{{ project.type }}" selected>{{ project.type|capitalize }}</option>
                                {% endif %}
                                <option value="other_custom">+ Add custom type...</option>
                            </select>
                        </div>
                        <div id="custom_type_container" class="mt-2 hidden">
                            <input type="text" id="custom_type" class="w-full bg-background border border-primary p-2 rounded" placeholder="Enter custom type..." oninput="document.getElementById('type_select').options[document.getElementById('type_select').selectedIndex].value = this.value;">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Status</label>
                        <div class="flex gap-2">
                            <select name="status" id="status_select" class="flex-grow bg-background border border-gray-600 p-2 rounded" onchange="if(this.value==='other_custom'){document.getElementById('custom_status_container').classList.remove('hidden');}else{document.getElementById('custom_status_container').classList.add('hidden');}">
                                <option value="current" {{ (formData.status|default(project.status|default(''))) == 'current' ? 'selected' : '' }}>Current</option>
                                <option value="past" {{ (formData.status|default(project.status|default(''))) == 'past' ? 'selected' : '' }}>Past</option>
                                {% if project.status and project.status not in ['current', 'past'] %}
                                    <option value="{{ project.status }}" selected>{{ project.status|capitalize }}</option>
                                {% endif %}
                                <option value="other_custom">+ Add custom status...</option>
                            </select>
                        </div>
                        <div id="custom_status_container" class="mt-2 hidden">
                            <input type="text" id="custom_status" class="w-full bg-background border border-primary p-2 rounded" placeholder="Enter custom status..." oninput="document.getElementById('status_select').options[document.getElementById('status_select').selectedIndex].value = this.value;">
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Start Date</label>
                        <input type="date" name="start_date" value="{{ formData.start_date|default(project.start_date|default('')) }}" class="w-full bg-background border border-gray-600 p-2 rounded">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">End Date</label>
                        <input type="date" name="end_date" value="{{ formData.end_date|default(project.end_date|default('')) }}" class="w-full bg-background border border-gray-600 p-2 rounded">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">GitHub URL</label>
                    <input type="url" name="github_url" value="{{ formData.github_url|default(project.github_url|default('')) }}" class="w-full bg-background border border-gray-600 p-2 rounded" placeholder="https://github.com/...">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Website URL</label>
                    <input type="url" name="website_url" value="{{ formData.website_url|default(project.website_url|default('')) }}" class="w-full bg-background border border-gray-600 p-2 rounded" placeholder="https://...">
                </div>
            </div>

            <!-- Right Column: Images/Gallery (Mockup) -->
            <div class="bg-surface p-6 rounded-lg shadow-md">
                <h2 class="text-xl font-bold border-b border-gray-700 pb-2 mb-4">Assets</h2>
                <div class="border-2 border-dashed border-gray-600 rounded-lg p-8 text-center text-gray-500">
                    <p>Drag and drop images here (Coming Soon)</p>
                </div>
            </div>
        </div>

        <!-- Language Specific Translations -->
        <div class="space-y-6">
            {% for lang in languages %}
            <div class="bg-surface p-6 rounded-lg shadow-md">
                <h2 class="text-xl font-bold border-b border-gray-700 pb-2 mb-4 flex items-center">
                    <span class="mr-2">{{ lang.code == 'fr' ? '🇫🇷' : '🇬🇧' }}</span>
                    Content ({{ lang.name }})
                </h2>
                {% set trans = projectTranslations[lang.code]|default({}) %}
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Title</label>
                        <input type="text" name="title_{{ lang.code }}" value="{{ formData['title_' ~ lang.code]|default(trans.title|default('')) }}" class="w-full bg-background border border-gray-600 p-2 rounded">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Subtitle</label>
                        <input type="text" name="subtitle_{{ lang.code }}" value="{{ formData['subtitle_' ~ lang.code]|default(trans.subtitle|default('')) }}" class="w-full bg-background border border-gray-600 p-2 rounded">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Description</label>
                        <textarea name="description_{{ lang.code }}" rows="4" class="w-full bg-background border border-gray-600 p-2 rounded">{{ formData['description_' ~ lang.code]|default(trans.description|default('')) }}</textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Skills (Select from list or type manual below)</label>
                        <div class="flex flex-wrap gap-2 mb-2" id="skill_tags_{{ lang.code }}">
                            {% for skill in (trans.skills|split(',')) %}
                                {% if skill|trim %}
                                <span class="bg-primary/20 border border-primary text-xs px-2 py-1 rounded flex items-center gap-1">
                                    {{ skill|trim }}
                                    <button type="button" onclick="this.parentElement.remove(); updateSkillsHidden('{{ lang.code }}')" class="hover:text-red-500">&times;</button>
                                </span>
                                {% endif %}
                            {% endfor %}
                        </div>
                        
                        <div class="flex gap-2">
                            <select class="flex-grow bg-background border border-gray-600 p-2 rounded" onchange="if(this.value) { addSkillTag('{{ lang.code }}', this.value); this.value=''; }">
                                <option value="">-- Quick add from skills --</option>
                                {% for category in categories %}
                                    <optgroup label="{{ category.name }}">
                                        {% for skill in category.competencies %}
                                            <option value="{{ skill.name }}">{{ skill.name }}</option>
                                        {% endfor %}
                                    </optgroup>
                                {% endfor %}
                            </select>
                            <input type="text" id="skill_input_{{ lang.code }}" class="bg-background border border-gray-600 p-2 rounded" placeholder="Type and Enter..." onkeydown="if(event.key==='Enter'){ event.preventDefault(); addSkillTag('{{ lang.code }}', this.value); this.value=''; }">
                        </div>
                        <input type="hidden" name="skills_{{ lang.code }}" id="skills_hidden_{{ lang.code }}" value="{{ formData['skills_' ~ lang.code]|default(trans.skills|default('')) }}">
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="flex justify-end pt-4">
            <button type="submit" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded font-bold transition-transform hover:scale-105">
                {{ isNew ? 'Create Project' : 'Save Changes' }}
            </button>
        </div>
    </form>
</div>

<script>
function addSkillTag(lang, value) {
    value = value.trim();
    if (!value) return;
    
    const container = document.getElementById('skill_tags_' + lang);
    const hidden = document.getElementById('skills_hidden_' + lang);
    
    // Check if already exists
    const existing = Array.from(container.querySelectorAll('span')).map(s => s.textContent.trim().replace('×','').trim());
    if (existing.includes(value)) return;

    const span = document.createElement('span');
    span.className = 'bg-primary/20 border border-primary text-xs px-2 py-1 rounded flex items-center gap-1';
    span.innerHTML = `${value} <button type="button" onclick="this.parentElement.remove(); updateSkillsHidden('${lang}')" class="hover:text-red-500">&times;</button>`;
    
    container.appendChild(span);
    updateSkillsHidden(lang);
}

function updateSkillsHidden(lang) {
    const container = document.getElementById('skill_tags_' + lang);
    const hidden = document.getElementById('skills_hidden_' + lang);
    const tags = Array.from(container.querySelectorAll('span')).map(s => s.textContent.trim().replace('×','').trim());
    hidden.value = tags.join(', ');
}
</script>
{% endblock %}
