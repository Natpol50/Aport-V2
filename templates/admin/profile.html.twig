{% extends 'admin/base.html.twig' %}

{% block title %}Manage Bio - Admin{% endblock %}

{% block content %}
<div class="admin-content container mx-auto px-4 py-8">
    <div class="mb-12">
        <h1 class="admin-title-trap text-2xl font-bold uppercase tracking-tight">Personal Information</h1>
    </div>

    <form action="/admin/personal-info/update" method="POST" class="space-y-12">
        <!-- Global Core Info -->
        <div class="bg-surface p-8 shadow-2xl border-l-4 border-primary">
            <h2 class="text-xl font-bold mb-8 uppercase tracking-widest text-primary flex items-center">
                <span class="w-2 h-6 bg-primary mr-3"></span>
                Core Identity & Links
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">Email Address</label>
                    <input type="email" name="email" value="{{ personalInfo.email }}" class="w-full bg-background border border-gray-600 p-4 focus:border-primary outline-none transition-all">
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">GitHub URL</label>
                    <input type="url" name="github_url" value="{{ personalInfo.github_url }}" class="w-full bg-background border border-gray-600 p-4 focus:border-primary outline-none transition-all">
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">LinkedIn URL</label>
                    <input type="url" name="linkedin_url" value="{{ personalInfo.linkedin_url }}" class="w-full bg-background border border-gray-600 p-4 focus:border-primary outline-none transition-all">
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">Discord URL (Optional)</label>
                    <input type="text" name="discord_url" value="{{ personalInfo.discord_url }}" class="w-full bg-background border border-gray-600 p-4 focus:border-primary outline-none transition-all">
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">Profile Picture URL</label>
                    <input type="text" name="profile_picture_url" value="{{ personalInfo.profile_picture_url }}" class="w-full bg-background border border-gray-600 p-4 focus:border-primary outline-none transition-all">
                </div>
            </div>
        </div>

        <!-- Language Specific About Me -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {% for lang in languages %}
            <div class="bg-surface p-8 shadow-2xl border-t-4 border-gray-700">
                <h2 class="text-xl font-bold mb-8 flex items-center">
                    <span class="text-3xl mr-4">{{ lang.code == 'fr' ? '🇫🇷' : '🇬🇧' }}</span>
                    <span class="uppercase tracking-widest">{{ lang.name }} Bio</span>
                </h2>
                
                <div>
                    <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">About Text ({{ lang.code|upper }})</label>
                    <textarea name="about_{{ lang.code }}" rows="10" class="w-full bg-background border border-gray-600 p-4 focus:border-primary outline-none transition-all leading-relaxed">{{ (personalInfoTranslations[lang.code].about_text)|default('') }}</textarea>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="flex justify-end pt-8">
            <button type="submit" class="admin-trap bg-primary hover:bg-primary-dark text-white px-12 py-4 font-bold uppercase tracking-widest text-lg shadow-2xl hover:translate-y-[-4px] transition-all">
                <span>Update Biography</span>
            </button>
        </div>
    </form>
</div>
{% endblock %}

