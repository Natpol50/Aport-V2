{% extends 'admin/base.html.twig' %}

{% block title %}User Settings - Admin{% endblock %}

{% block content %}
<div class="admin-content container mx-auto px-4 py-8">
    <div class="mb-12">
        <h1 class="admin-title-trap text-2xl font-bold uppercase tracking-tight">{{ translations.translate('admin.user_profile') }}</h1>
    </div>

    <div class="max-w-2xl mx-auto">
        <form action="/admin/profile/update" method="POST" class="space-y-8">
            <div class="bg-surface p-8 shadow-2xl border-l-4 border-blue-600">
                <h2 class="text-xl font-bold mb-8 uppercase tracking-widest flex items-center">
                    <span class="w-2 h-6 bg-blue-600 mr-3"></span>
                    Account Credentials
                </h2>
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">Email Address</label>
                        <input type="email" name="email" value="{{ user.email }}" required class="w-full bg-background border border-gray-700 p-4 focus:border-blue-600 outline-none">
                    </div>

                    <div class="pt-6 border-t border-gray-800">
                        <p class="text-[10px] uppercase tracking-[0.2em] mb-6 text-gray-500">Change Password (Leave blank to keep current)</p>
                        
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">Current Password</label>
                                <input type="password" name="current_password" class="w-full bg-background border border-gray-700 p-4 focus:border-blue-600 outline-none">
                            </div>
                            <div>
                                <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">New Password</label>
                                <input type="password" name="new_password" class="w-full bg-background border border-gray-700 p-4 focus:border-blue-600 outline-none">
                            </div>
                            <div>
                                <label class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">Confirm New Password</label>
                                <input type="password" name="confirm_password" class="w-full bg-background border border-gray-700 p-4 focus:border-blue-600 outline-none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-center">
                <button type="submit" class="admin-trap bg-blue-600 hover:bg-blue-500 text-white px-12 py-4 font-bold uppercase tracking-widest text-lg shadow-2xl hover:translate-y-[-4px] transition-all">
                    <span>Update Account</span>
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}