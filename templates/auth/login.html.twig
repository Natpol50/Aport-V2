{% extends 'admin/base.html.twig' %}

{% block title %}{{ translations.translate('login.title') }} - {{ translations.translate('site.title') }}{% endblock %}

{% block content %}
<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
        <div class="text-center mb-12">
            <img class="mx-auto h-24 w-auto mb-6" src="/assets/img/AshaLogo.png" alt="Logo">
            <h2 class="admin-title-trap inline-block px-12 py-3 text-3xl font-bold uppercase tracking-widest">
                {{ translations.translate('login.title') }}
            </h2>
        </div>
        
        <div class="bg-surface p-8 shadow-2xl border-l-4 border-primary">
            <form class="space-y-8" action="/login" method="POST">
                <div class="space-y-6">
                    <div>
                        <label for="email" class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">{{ translations.translate('login.email') }}</label>
                        <input id="email" name="email" type="email" autocomplete="email" required 
                            value="{{ formData.email|default('') }}"
                            class="w-full bg-background border border-gray-700 p-4 focus:border-primary outline-none transition-all" 
                            placeholder="Email address">
                    </div>
                    <div>
                        <label for="password" class="block text-xs uppercase tracking-widest font-bold mb-2 opacity-50">{{ translations.translate('login.password') }}</label>
                        <input id="password" name="password" type="password" autocomplete="current-password" required 
                            class="w-full bg-background border border-gray-700 p-4 focus:border-primary outline-none transition-all" 
                            placeholder="Password">
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center">
                        <input id="remember_me" name="remember_me" type="checkbox" 
                            {% if formData.remember_me|default(false) %}checked{% endif %}
                            class="h-4 w-4 text-primary focus:ring-primary bg-background border-gray-600">
                        <label for="remember_me" class="ml-2 block text-sm text-gray-400">
                            {{ translations.translate('login.remember_me') }}
                        </label>
                    </div>
                </div>

                <div>
                    <button type="submit" class="admin-trap w-full bg-primary hover:bg-primary-dark text-white py-4 font-bold uppercase tracking-widest text-lg shadow-xl hover:translate-y-[-2px] transition-all">
                        <span>{{ translations.translate('login.submit') }}</span>
                    </button>
                </div>
            </form>
        </div>
        
        <div class="mt-8 text-center text-gray-500 text-xs uppercase tracking-[0.2em]">
            &copy; {{ "now"|date("Y") }} Aport Security Access
        </div>
    </div>
</div>
{% endblock %}
